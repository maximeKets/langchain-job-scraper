# Clé API OpenAI (Requis pour ChatGPT)
OPENAI_API_KEY=votre_cle_api_openai_ici

# Choix du modèle (ex: gpt-4o, gpt-4o-mini, gpt-3.5-turbo)
MODEL_NAME=gpt-4o

# --- Configuration LangSmith (Pour le debug et la trace des agents) ---
LANGCHAIN_TRACING=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=votre_cle_api_langsmith_ici
LANGCHAIN_PROJECT=langchain-job-scraper
# ----------------------------------------------------------------------

# Configuration de la base de données (Optionnel)
DB_PATH=sqlite:///sqlite.db
JOB_SEARCH_CONFIG_PATH=config/job_search.yaml

# Découverte automatique de boards Lever via Serper.dev
SERPER_API_KEY=votre_cle_api_serper_ici
SERPER_RESULTS_PER_QUERY=10

# Email de réception des résumés
RECIPIENT_EMAIL=lorem@gmail.com
EMAIL_DELIVERY_MODE=mock

# Configuration SMTP (Optionnel, pour l'envoi réel d'emails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=votre_email_d_envoi@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_d_application
